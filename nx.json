{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "release": {
        "projectsRelationship": "independent",
        "version": {
            "conventionalCommits": true
        },
        "changelog": {
            "projectChangelogs": {
                "createRelease": "github",
                "file": false
            }
        },
        "git": {
            "commit": false,
            "tag": true
        }
    },
    "targetDefaults": {
        "build": {
            "outputs": ["{projectRoot}/dist"],
            "cache": true
        },
        "test": {
            "cache": true
        },
        "lint": {
            "cache": true
        }
    }
}
