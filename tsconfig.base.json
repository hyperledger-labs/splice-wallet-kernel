{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "composite": false,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "esModuleInterop": true,
        "exactOptionalPropertyTypes": true,
        "strict": true,
        "skipLibCheck": true
    },
    "exclude": [
        "${configDir}/dist",
        "${configDir}/build",
        "${configDir}/**/*.spec.ts",
        "${configDir}/**/*.test.ts",
        "${configDir}/**/__tests__/**"
    ]
}
